{
  "name": "openclaw-board",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/openclaw-board/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/openclaw-board",
        "index": "apps/openclaw-board/src/index.html",
        "browser": "apps/openclaw-board/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/openclaw-board/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/openclaw-board/public"
          }
        ],
        "styles": ["apps/openclaw-board/src/styles.scss"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "options": {
        "proxyConfig": "apps/openclaw-board/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "openclaw-board:build:production"
        },
        "development": {
          "buildTarget": "openclaw-board:build:development"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true
    },
    "serve-api": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/openclaw-board/server.js"
      },
      "continuous": true
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "commands": [
          "nx run openclaw-board:serve-api",
          "nx run openclaw-board:serve"
        ]
      },
      "continuous": true
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "openclaw-board:build",
        "port": 4200,
        "staticFilePath": "dist/apps/openclaw-board/browser",
        "spa": true
      }
    }
  }
}