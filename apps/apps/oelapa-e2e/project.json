{
  "name": "oelapa-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/oelapa-e2e/src",
  "implicitDependencies": ["oelapa"],
  "// targets": "to see all targets run: nx show project oelapa-e2e --web",
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": [
        "{workspaceRoot}/dist/.playwright",
        "{workspaceRoot}/playwright-report",
        "{workspaceRoot}/test-results"
      ],
      "options": {
        "config": "apps/oelapa-e2e/playwright.config.ts"
      }
    },
    "e2e-ci": {
      "executor": "@nx/playwright:playwright",
      "outputs": [
        "{workspaceRoot}/dist/.playwright",
        "{workspaceRoot}/playwright-report",
        "{workspaceRoot}/test-results"
      ],
      "options": {
        "config": "apps/oelapa-e2e/playwright.config.ts"
      },
      "configurations": {
        "ci": {
          "forbidOnly": true,
          "retries": 2
        }
      }
    }
  }
}
