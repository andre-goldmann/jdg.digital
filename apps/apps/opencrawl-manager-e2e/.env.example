# Environment Variables for OpenCrawl Manager E2E

# Discord Integration
# Create a webhook in your Discord channel settings and paste the URL here
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Slack Integration
# Create an incoming webhook in your Slack workspace and paste the URL here
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Microsoft Teams Integration
# Create an incoming webhook in your Teams channel and paste the URL here
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/YOUR_WEBHOOK_URL

# Telegram Integration
# Create a bot and get the bot token and chat ID
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Base URL for the application (if different from default)
# BASE_URL=http://localhost:4200

# Test timeout (in milliseconds)
# TEST_TIMEOUT=30000

# Headless mode (true/false)
# HEADLESS=true
