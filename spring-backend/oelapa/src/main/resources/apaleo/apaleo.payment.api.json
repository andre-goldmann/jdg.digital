  "definitions": {
    "CancelPaymentModel": {
      "type": "object",
      "properties": {
        "reference": {
          "description": "Optional reference value",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "example": "{\n  \"reference\": \"Some reference value\"\n}"
    },
    "InvoiceListModel": {
      "required": [
        "count",
        "invoices"
      ],
      "type": "object",
      "properties": {
        "invoices": {
          "description": "The list of invoices",
          "type": "array",
          "items": {
            "$ref": "#/definitions/InvoiceModel"
          }
        },
        "count": {
          "format": "int64",
          "description": "Total count of items",
          "type": "integer"
        }
      },
      "additionalProperties": false,
      "example": "{\n  \"invoices\": [\n    {\n      \"id\": \"GIRVAKJD\",\n      \"merchantAccountCode\": \"ApaleoGmbHCOM\",\n      \"invoiceNumber\": \"APA12345\",\n      \"type\": \"PaymentProcessing\",\n      \"invoiceDate\": \"2025-11-15\"\n    },\n    {\n      \"id\": \"XVIRSAKJ\",\n      \"merchantAccountCode\": \"ApaleoGmbHPOS\",\n      \"invoiceNumber\": \"APA12378\",\n      \"type\": \"TerminalSale\",\n      \"invoiceDate\": \"2025-11-15\"\n    }\n  ],\n  \"count\": 2\n}"
    },
    "InvoiceModel": {
      "required": [
        "id",
        "invoiceDate",
        "invoiceNumber",
        "merchantAccountCode",
        "type"
      ],
      "type": "object",
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "merchantAccountCode": {
          "minLength": 1,
          "type": "string"
        },
        "invoiceNumber": {
          "minLength": 1,
          "type": "string"
        },
        "type": {
          "enum": [
            "PaymentProcessing",
            "TerminalService",
            "TerminalSale"
          ],
          "type": "string"
        },
        "invoiceDate": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "example": "{\n  \"id\": \"GIRVAKJD\",\n  \"merchantAccountCode\": \"ApaleoGmbHCOM\",\n  \"invoiceNumber\": \"APA12345\",\n  \"type\": \"PaymentProcessing\",\n  \"invoiceDate\": \"2025-11-15\"\n}"
    },
    "MessageItem": {
      "type": "object",
      "properties": {
        "code": {
          "format": "int32",
          "type": "integer"
        },
        "text": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "MessageItemCollection": {
      "type": "object",
      "properties": {
        "messages": {
