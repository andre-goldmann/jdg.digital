          "422": {
            "description": "The request is automatically cancelled after 120 seconds if no action is taken on the terminal.\r\n            \r\nValidation errors in the request body.\r\n            \r\n1000 - Generic validation error\r\n            \r\n1001 - The payment provider is not properly configured\r\n            \r\n2600 - Payment request failed",
            "schema": {
              "$ref": "#/definitions/MessageItemCollection"
            }
          },
          "415": {
            "description": "Unsupported media type."
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "You are unauthorized."
          },
          "403": {
            "description": "Forbidden."
          },
          "404": {
            "description": "The Request-URI could not be found."
          },
          "500": {
            "description": "An unexpected error occurred."
          },
          "503": {
            "description": "The server is currently unavailable. Please try later."
          }
        },
        "security": [
          {
            "oauth2": [
              "payment:admin",
              "payment:transactions.manage"
            ]
          }
        ]
      }
    },
