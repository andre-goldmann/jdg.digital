  },
  "paths": {
    "/payment/v1/configuration/properties": {
      "get": {
        "tags": [
          "Configuration"
        ],
        "summary": "Get list of property configurations",
        "description": "Get list of property configurations in the current account.<br>You must have at least one of these scopes: 'payment:configuration.read, payment:configuration.manage, payment:admin'.",
        "operationId": "PaymentConfigurationPropertiesGet",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "Return all property configurations.",
            "schema": {
              "$ref": "#/definitions/PropertyConfigurationListModel"
            }
          },
          "204": {
            "description": "There are no property configurations found."
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "You are unauthorized."
          },
          "403": {
            "description": "Forbidden."
          },
          "404": {
            "description": "The Request-URI could not be found."
          },
          "500": {
            "description": "An unexpected error occurred."
          },
          "503": {
            "description": "The server is currently unavailable. Please try later."
          }
        },
        "security": [
          {
            "oauth2": [
              "payment:configuration.read",
              "payment:configuration.manage",
              "payment:admin"
            ]
          }
        ]
