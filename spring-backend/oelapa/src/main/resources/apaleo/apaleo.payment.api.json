      "additionalProperties": false,
      "example": "{\n  \"transactions\": [\n    {\n      \"pspReference\": \"8815360785594505\",\n      \"amount\": {\n        \"currency\": \"EUR\",\n        \"value\": 190.0\n      },\n      \"merchantReference\": \"something\",\n      \"merchantAccountCode\": \"MyHotelCOM\",\n      \"terminalId\": \"T400-1234567\",\n      \"originalFolioId\": \"XKCDER-1-1\",\n      \"propertyId\": \"BER\",\n      \"journal\": [\n        {\n          \"pspReference\": \"8815360785594505\",\n          \"amount\": {\n            \"currency\": \"EUR\",\n            \"value\": 190.0\n          },\n          \"eventCode\": \"AUTHORISATION\",\n          \"dateTime\": \"2025-11-16T11:44:44.0799174Z\",\n          \"isSuccess\": false,\n          \"reason\": \"Refused\",\n          \"refusalReason\": \"05 : Do not honor\"\n        },\n        {\n          \"pspReference\": \"862623095673169A\",\n          \"amount\": {\n            \"currency\": \"EUR\",\n            \"value\": 100.0\n          },\n          \"eventCode\": \"CAPTURE\",\n          \"dateTime\": \"2025-11-16T11:45:44.079922Z\",\n          \"isSuccess\": true\n        },\n        {\n          \"pspReference\": \"862623087842791E\",\n          \"amount\": {\n            \"currency\": \"EUR\",\n            \"value\": 90.0\n          },\n          \"eventCode\": \"CAPTURE\",\n          \"dateTime\": \"2025-11-16T11:46:44.0799226Z\",\n          \"isSuccess\": true\n        },\n        {\n          \"pspReference\": \"862623087842791E\",\n          \"amount\": {\n            \"currency\": \"EUR\",\n            \"value\": 70.0\n          },\n          \"eventCode\": \"CAPTURE\",\n          \"dateTime\": \"2025-11-16T11:47:44.0799231Z\",\n          \"isSuccess\": true,\n          \"reason\": \"Insufficient balance on payment\"\n        },\n        {\n          \"pspReference\": \"862623094473133B\",\n          \"amount\": {\n            \"currency\": \"EUR\",\n            \"value\": 10.0\n          },\n          \"eventCode\": \"REFUND\",\n          \"dateTime\": \"2025-11-16T12:16:44.0799236Z\",\n          \"isSuccess\": false\n        }\n      ]\n    }\n  ],\n  \"count\": 1\n}"
    },
    "PaymentTransactionModel": {
      "required": [
        "amount",
        "merchantAccountCode",
        "merchantReference",
        "originalFolioId",
        "propertyId",
        "pspReference"
      ],
      "type": "object",
      "properties": {
        "pspReference": {
          "description": "The PSP reference of this transaction",
          "minLength": 1,
          "type": "string"
        },
        "amount": {
          "$ref": "#/definitions/MonetaryValueModel"
        },
        "merchantReference": {
          "description": "The reference provided when the payment transaction was initiated",
          "minLength": 1,
          "type": "string"
        },
        "merchantAccountCode": {
          "description": "The merchant account on the payment processor this transaction is registered for. This transaction will\r\nshow up in the settlement report for this merchant account and be paid out to the bank account registered\r\nfor this merchant",
          "minLength": 1,
          "type": "string"
        },
        "terminalId": {
          "description": "Terminal Id used to perform this payment, when a POS payment",
          "type": "string"
        },
        "originalFolioId": {
          "description": "The folio id in apaleo core that this payment was originally done for",
          "minLength": 1,
          "type": "string"
        },
        "propertyId": {
          "description": "The property id in apaleo core that this payment belongs to",
          "minLength": 1,
          "type": "string"
        },
        "journal": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PaymentJournalEntryModel"
          }
        }
      },
      "additionalProperties": false,
      "example": "{\n  \"pspReference\": \"8815360785594505\",\n  \"amount\": {\n    \"currency\": \"EUR\",\n    \"value\": 190.0\n  },\n  \"merchantReference\": \"something\",\n  \"merchantAccountCode\": \"MyHotelCOM\",\n  \"terminalId\": \"T400-1234567\",\n  \"originalFolioId\": \"XKCDER-1-1\",\n  \"propertyId\": \"BER\",\n  \"journal\": [\n    {\n      \"pspReference\": \"8815360785594505\",\n      \"amount\": {\n        \"currency\": \"EUR\",\n        \"value\": 190.0\n      },\n      \"eventCode\": \"AUTHORISATION\",\n      \"dateTime\": \"2025-11-16T11:44:44.0758137Z\",\n      \"isSuccess\": false,\n      \"reason\": \"Refused\",\n      \"refusalReason\": \"05 : Do not honor\"\n    },\n    {\n      \"pspReference\": \"862623095673169A\",\n      \"amount\": {\n        \"currency\": \"EUR\",\n        \"value\": 100.0\n      },\n      \"eventCode\": \"CAPTURE\",\n      \"dateTime\": \"2025-11-16T11:45:44.0758211Z\",\n      \"isSuccess\": true\n    },\n    {\n      \"pspReference\": \"862623087842791E\",\n      \"amount\": {\n        \"currency\": \"EUR\",\n        \"value\": 90.0\n      },\n      \"eventCode\": \"CAPTURE\",\n      \"dateTime\": \"2025-11-16T11:46:44.0758216Z\",\n      \"isSuccess\": true\n    },\n    {\n      \"pspReference\": \"862623087842791E\",\n      \"amount\": {\n        \"currency\": \"EUR\",\n        \"value\": 70.0\n      },\n      \"eventCode\": \"CAPTURE\",\n      \"dateTime\": \"2025-11-16T11:47:44.075822Z\",\n      \"isSuccess\": true,\n      \"reason\": \"Insufficient balance on payment\"\n    },\n    {\n      \"pspReference\": \"862623094473133B\",\n      \"amount\": {\n        \"currency\": \"EUR\",\n        \"value\": 10.0\n      },\n      \"eventCode\": \"REFUND\",\n      \"dateTime\": \"2025-11-16T12:16:44.0758224Z\",\n      \"isSuccess\": false\n    }\n  ]\n}"
