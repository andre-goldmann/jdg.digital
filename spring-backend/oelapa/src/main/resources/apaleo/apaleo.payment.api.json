        ],
        "summary": "Cancels the outstanding payment authorization using the supplied apaleo payment transaction id or authorization PSP reference",
        "description": "<br>You must have at least one of these scopes: 'payment:admin, payment:transactions.manage'.",
        "operationId": "PaymentPayment-transaction-actionsByIdCancelPut",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "Apaleo payment transaction id or PSP reference",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "",
            "schema": {
              "$ref": "#/definitions/CancelPaymentModel"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          },
          "422": {
            "description": "Transaction is not cancellable",
            "schema": {
              "$ref": "#/definitions/MessageItemCollection"
            }
          },
          "415": {
            "description": "Unsupported media type."
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "You are unauthorized."
          },
          "403": {
            "description": "Forbidden."
          },
          "404": {
            "description": "The Request-URI could not be found."
          },
          "500": {
            "description": "An unexpected error occurred."
          },
          "503": {
            "description": "The server is currently unavailable. Please try later."
          }
        },
        "security": [
          {
            "oauth2": [
              "payment:admin",
              "payment:transactions.manage"
            ]
          }
        ]
      }
    },
    "/payment/v1/payment-transactions/by-terminal": {
      "post": {
        "tags": [
          "PaymentTransactions"
        ],
        "summary": "Request a AutoExpire payment authorization performed on a card terminal",
        "description": "Will be deprecated soon! Please, use ```/v1/payment-transactions/by-terminal/autoexpire``` instead.\r\n            \r\nInitialize a payment authorization on a given card terminal. The API is waiting for the transaction on the terminal\r\nto either finish or time out after 120 seconds.\r\nPoll the transactions api\r\n```/payment/v1/transactions?merchantReference={MerchantReference}&pageNumber=1&pageSize=100```\r\nbased on the merchant reference for the status of the payment.<br>You must have at least one of these scopes: 'payment:admin, payment:transactions.manage'.",
        "operationId": "PaymentPayment-transactionsBy-terminalPost",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "flow",
            "description": "Purpose of payment transaction, must be AutoExpire",
            "type": "string",
            "enum": [
              "None",
              "AutoExpire",
              "BlockNHold"
            ]
          },
          {
            "in": "body",
            "name": "body",
            "description": "",
            "schema": {
              "$ref": "#/definitions/RequestTerminalPaymentAuthorizationModel"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "422": {
            "description": "The request is automatically cancelled after 120 seconds if no action is taken on the terminal.\r\n            \r\nValidation errors in the request body.\r\n            \r\n1000 - Generic validation error\r\n            \r\n1001 - The payment provider is not properly configured\r\n            \r\n2600 - Payment request failed",
            "schema": {
              "$ref": "#/definitions/MessageItemCollection"
            }
          },
          "415": {
            "description": "Unsupported media type."
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "You are unauthorized."
          },
          "403": {
            "description": "Forbidden."
          },
          "404": {
            "description": "The Request-URI could not be found."
          },
          "500": {
            "description": "An unexpected error occurred."
          },
          "503": {
            "description": "The server is currently unavailable. Please try later."
          }
        },
        "deprecated": true,
        "security": [
          {
            "oauth2": [
              "payment:admin",
              "payment:transactions.manage"
            ]
          }
        ]
      }
    },
    "/payment/v1/payment-transactions/by-terminal/autoexpire": {
      "post": {
