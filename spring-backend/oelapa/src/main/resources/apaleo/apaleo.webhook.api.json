  "definitions": {
    "CreateSubscriptionRequestModel": {
      "required": [
        "endpointUrl"
      ],
      "type": "object",
      "properties": {
        "endpointUrl": {
          "description": "Endpoint to which notifications will be sent to",
          "minLength": 1,
          "type": "string"
        },
        "topics": {
          "description": "Subscribe to events from the provided topics",
          "type": "array",
          "items": {
            "enum": [
              "Reservation",
              "Folio",
              "Invoice",
              "RatePlan",
              "Group",
              "Block",
              "Unit",
              "NightAudit",
              "Fiscalization",
              "Booking",
              "Company",
              "UnitGroup",
              "Maintenance",
              "Account",
              "Property",
              "CityTax",
              "Service",
              "UnitAttributeDefinition",
              "PaymentTransaction"
            ],
            "type": "string"
          }
        },
        "events": {
          "description": "Events for which you want to receive notifications",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "propertyIds": {
          "description": "List of Ids for the properties for which the subscription is configured\r\nIf the list is empty then the webhooks will be delivered for all properties.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "example": "{\n  \"endpointUrl\": \"https://example.com\",\n  \"events\": [\n    \"booking/created\",\n    \"booking/changed\",\n    \"reservation/*\"\n  ],\n  \"propertyIds\": [\n    \"MUC\",\n    \"BER\"\n  ]\n}"
    },
    "CreateSubscriptionResponseModel": {
      "description": "The reason behind this model which is basically the same old SubscriptionCreatedResponseModel\r\nis that in the old implementation of notifications, the Id property was called SubscriptionId,\r\nand in order to keep consistency with the Apaleo environment\r\nthe property should be called Id for the new implementation of webhooks.",
      "type": "object",
      "properties": {
        "id": {
          "format": "uuid",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ErrorResponseModel": {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "HealthcheckFailed",
            "EnabledForAnotherEndpoint",
            "InvalidPropertyId"
          ],
          "type": "string"
        },
        "message": {
          "type": "string",
          "readOnly": true
        }
      },
      "additionalProperties": false,
      "example": "{\n  \"type\": \"HealthcheckFailed\",\n  \"message\": \"Could not enable subscription for non responsive endpoint\"\n}"
    },
    "MessageItemCollection": {
      "type": "object",
      "properties": {
        "messages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "readOnly": true
        }
      },
      "additionalProperties": false
    },
    "ReplaceSubscriptionModel": {
      "required": [
        "endpointUrl"
      ],
      "type": "object",
      "properties": {
        "endpointUrl": {
          "description": "Endpoint to which notifications will be sent to",
          "minLength": 1,
          "type": "string"
        },
        "topics": {
          "description": "Subscribe to events from the provided topics",
          "type": "array",
          "items": {
            "enum": [
              "Reservation",
              "Folio",
              "Invoice",
              "RatePlan",
              "Group",
              "Block",
              "Unit",
              "NightAudit",
              "Fiscalization",
              "Booking",
              "Company",
              "UnitGroup",
              "Maintenance",
              "Account",
              "Property",
              "CityTax",
              "Service",
              "UnitAttributeDefinition",
              "PaymentTransaction"
            ],
            "type": "string"
          }
        },
        "events": {
          "description": "Events for which you want to receive notifications",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "propertyIds": {
          "description": "List of Ids for the properties for which the subscription is configured\r\nIf the list is empty then the webhooks will be delivered for all properties.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "example": "{\n  \"endpointUrl\": \"https://www.example.com\",\n  \"events\": [\n    \"booking/created\",\n    \"booking/changed\",\n    \"reservation/*\"\n  ],\n  \"propertyIds\": [\n    \"MUC\",\n    \"BER\"\n  ]\n}"
    },
    "SubscriptionResponseModel": {
      "required": [
        "created",
        "endpointUrl",
        "id"
      ],
      "type": "object",
      "properties": {
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "topics": {
          "type": "array",
          "items": {
            "enum": [
              "Reservation",
              "Folio",
              "Invoice",
              "RatePlan",
              "Group",
              "Block",
              "Unit",
              "NightAudit",
              "Fiscalization",
              "Booking",
              "Company",
              "UnitGroup",
              "Maintenance",
              "Account",
              "Property",
              "CityTax",
              "Service",
              "UnitAttributeDefinition",
              "PaymentTransaction"
            ],
            "type": "string"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "endpointUrl": {
          "format": "uri",
          "type": "string"
        },
        "created": {
          "format": "date-time",
          "type": "string"
        },
        "propertyIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "securityDefinitions": {
    "oauth2": {
      "type": "oauth2",
      "flow": "implicit",
      "authorizationUrl": "https://identity.apaleo.com/connect/authorize",
      "scopes": {
        "notifications:admin": "Create/Modify/Delete subscriptions (Admin)"
      }
    }
  }
}